# === ALWAYS REVIEW BEFORE COMMITTING ===

# Files that SHOULD typically be in git but require careful review:
# - requirements.txt (review for version pinning)
# - config.example.yaml (example, not real creds)
# - docker-compose.yml (review for secrets)
# - .github/workflows/*.yml (review for hardcoded values)

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

